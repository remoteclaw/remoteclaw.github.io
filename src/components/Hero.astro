---
---

<section class="px-6 py-20 text-center sm:py-28 lg:py-36">
    <div class="mx-auto max-w-3xl">
        <h1 class="font-heading text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
            Your <span class="font-mono text-accent">~/.<span class="text-accent-light">&lt;agent&gt;</span></span> &mdash; remotely.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary sm:text-xl">
            Self-hosted middleware that connects Claude Code, Gemini CLI,
            Codex CLI, and OpenCode to 20+ messaging channels.
        </p>
        <div class="mt-10 flex flex-col items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="inline-flex rounded-lg border border-border p-0.5 text-xs" role="tablist">
                    <button class="hero-tab rounded-md px-3 py-1" role="tab" aria-selected="true" data-tab="macos-linux">macOS/Linux/WSL</button>
                    <button class="hero-tab rounded-md px-3 py-1" role="tab" aria-selected="false" data-tab="windows">Windows</button>
                    <button class="hero-tab rounded-md px-3 py-1" role="tab" aria-selected="false" data-tab="npm">npm</button>
                </div>
                <label class="group/next inline-flex items-center gap-1.5 cursor-pointer text-xs select-none relative">
                    <input type="checkbox" id="hero-next-toggle" class="hero-checkbox" />
                    <span id="hero-next-label" class="text-text-secondary">next</span>
                    <span class="hero-tooltip">
                        The frontier &mdash; tracks every commit on main. Newest features, updated continuously.
                    </span>
                </label>
            </div>
            <div
                id="hero-install"
                class="group relative inline-flex cursor-pointer items-center rounded-lg border border-border bg-bg-surface px-5 py-3 font-mono text-sm transition-colors hover:border-accent/50"
                role="button"
                tabindex="0"
            >
                <span id="hero-prompt" class="text-text-secondary">$</span>
                <span id="hero-command" class="ml-2 select-all text-text-primary">curl -fsSL remoteclaw.sh | sh</span>
                <span id="hero-copy-label" class="ml-3 text-text-secondary transition-colors group-hover:text-accent-light">
                    <svg class="hero-copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </span>
            </div>
            <a
                href="https://docs.remoteclaw.org"
                class="text-sm text-text-secondary transition-colors hover:text-accent-light"
            >
                Read the docs &rarr;
            </a>
        </div>
    </div>
</section>

<style>
    .hero-tab {
        transition: color 0.15s, background-color 0.15s;
        color: var(--color-text-secondary);
        cursor: pointer;
    }
    .hero-tab[aria-selected="true"] {
        background-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
        color: var(--color-accent);
    }
    .hero-tab:hover:not([aria-selected="true"]) {
        color: var(--color-text-primary);
    }
    .hero-checkbox {
        accent-color: var(--color-accent);
    }
    #hero-next-label {
        color: color-mix(in srgb, var(--color-accent) 40%, var(--color-text-secondary));
    }
    .hero-tooltip {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%);
        width: max-content;
        max-width: 260px;
        padding: 6px 10px;
        border-radius: 6px;
        background-color: var(--color-bg-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text-secondary);
        font-size: 11px;
        line-height: 1.4;
        text-align: left;
        z-index: 10;
    }
    .group\/next:hover .hero-tooltip {
        display: block;
    }
</style>

<script>
    const heroInstall = document.getElementById("hero-install")!;
    const heroCommand = document.getElementById("hero-command")!;
    const heroPrompt = document.getElementById("hero-prompt")!;
    const heroCopyLabel = document.getElementById("hero-copy-label")!;
    const heroTabs = document.querySelectorAll(".hero-tab");
    const heroNextToggle = document.getElementById("hero-next-toggle") as HTMLInputElement;
    const heroNextLabel = document.getElementById("hero-next-label")!;

    const commands: Record<string, { stable: string; next: string; prompt: string }> = {
        "macos-linux": {
            stable: "curl -fsSL remoteclaw.sh | sh",
            next: "curl -fsSL next.remoteclaw.sh | sh",
            prompt: "$",
        },
        windows: {
            stable: "irm remoteclaw.ps | iex",
            next: "irm next.remoteclaw.ps | iex",
            prompt: ">",
        },
        npm: {
            stable: "npm install -g remoteclaw",
            next: "npm install -g remoteclaw@next",
            prompt: "$",
        },
    };

    let activeTab = "macos-linux";

    function updateHero() {
        const channel = heroNextToggle.checked ? "next" : "stable";
        const entry = commands[activeTab];
        heroCommand.textContent = entry[channel];
        heroPrompt.textContent = entry.prompt;
        setCopyIcon();
        heroNextLabel.style.color = heroNextToggle.checked ? "var(--color-accent)" : "";
    }

    heroTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            activeTab = (tab as HTMLElement).dataset.tab!;
            heroTabs.forEach((t) => {
                t.setAttribute("aria-selected", String((t as HTMLElement).dataset.tab === activeTab));
            });
            updateHero();
        });
    });

    heroNextToggle.addEventListener("change", updateHero);

    const copyIconSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
    const checkIconSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

    function setCopyIcon() {
        heroCopyLabel.innerHTML = copyIconSvg;
    }

    heroInstall.addEventListener("click", () => {
        const channel = heroNextToggle.checked ? "next" : "stable";
        navigator.clipboard.writeText(commands[activeTab][channel]);
        heroCopyLabel.innerHTML = checkIconSvg;
        setTimeout(() => setCopyIcon(), 2000);
    });
</script>

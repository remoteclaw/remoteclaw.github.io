---

<section id="install" class="border-t border-border px-6 py-16">
    <div class="mx-auto max-w-xl text-center">
        <h2 class="font-heading text-2xl font-bold sm:text-3xl">
            Get started
        </h2>
        <p class="mt-3 text-text-secondary">
            Install RemoteClaw in seconds.
        </p>
        <div class="mt-8 space-y-3">
            <div class="flex items-center justify-between rounded-lg border border-border bg-bg-surface px-5 py-3 font-mono text-sm">
                <div>
                    <span class="text-text-secondary">$</span>
                    <span class="ml-2 select-all text-text-primary">npm install -g remoteclaw</span>
                </div>
                <button
                    class="copy-btn text-text-secondary transition-colors hover:text-accent-light"
                    data-text="npm install -g remoteclaw"
                    type="button"
                >
                    copy
                </button>
            </div>
            <div class="flex items-center justify-between rounded-lg border border-border bg-bg-surface px-5 py-3 font-mono text-sm">
                <div>
                    <span class="text-text-secondary">$</span>
                    <span class="ml-2 select-all text-text-primary">curl -fsSL remoteclaw.org/install.sh | sh</span>
                </div>
                <button
                    class="copy-btn text-text-secondary transition-colors hover:text-accent-light"
                    data-text="curl -fsSL remoteclaw.org/install.sh | sh"
                    type="button"
                >
                    copy
                </button>
            </div>
        </div>
    </div>
</section>

<script>
    document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            const text = (btn as HTMLElement).dataset.text;
            if (text) {
                navigator.clipboard.writeText(text);
                btn.textContent = "copied!";
                setTimeout(() => (btn.textContent = "copy"), 2000);
            }
        });
    });
</script>

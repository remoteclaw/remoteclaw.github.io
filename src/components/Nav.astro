---
import { BookOpen, Github } from "@lucide/astro";
---

<nav class="border-b border-border">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2">
            <img src="/logo-64.png" alt="RemoteClaw" width="32" height="32" />
            <span class="font-heading text-lg font-bold text-text-primary">
                RemoteClaw
            </span>
        </a>
        <div class="flex items-center gap-4 text-sm text-text-secondary sm:gap-6">
            <a
                href="https://docs.remoteclaw.org"
                class="transition-colors hover:text-accent-light"
                title="Docs"
            >
                <BookOpen class="h-5 w-5 sm:hidden" />
                <span class="hidden sm:inline">Docs</span>
            </a>
            <a
                href="https://github.com/remoteclaw/remoteclaw"
                class="transition-colors hover:text-accent-light"
                title="GitHub"
            >
                <Github class="h-5 w-5 sm:hidden" />
                <span class="hidden sm:inline">GitHub</span>
            </a>
        </div>
    </div>
</nav>
